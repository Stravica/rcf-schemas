{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.stravica.io/rcf/v0.2.0/manifest.schema.json",
  "title": "RCF Project Manifest",
  "description": "Project manifest. Roots-only shape: declares prd, tad, bs. Children are owned by their parents and discovered by walking from the roots.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "projectName", "prd", "tad", "bs"],
  "properties": {
    "version": { "type": "string", "const": "2.0.0" },
    "projectName": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "prd": { "$ref": "https://schemas.stravica.io/rcf/v0.2.0/common.schema.json#/$defs/docRef" },
    "tad": { "$ref": "https://schemas.stravica.io/rcf/v0.2.0/common.schema.json#/$defs/docRef" },
    "bs": { "$ref": "https://schemas.stravica.io/rcf/v0.2.0/common.schema.json#/$defs/docRef" }
  }
}
