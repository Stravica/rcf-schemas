{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.stravica.io/rcf/v0.3.0/build-sequence.schema.json",
  "title": "RCF Build Sequence",
  "description": "One per project. Pure planning shell. FBSs each carry the mandatory bsId parent reference plus buildOrder; the ordered FBS list is computed by loading every FBS under rcf/fbs/, filtering by bsId, and sorting by buildOrder. Duplicate buildOrder within one BS is a validation error at load time.",
  "type": "object",
  "additionalProperties": false,
  "required": ["bsId", "prdId", "version", "status", "createdAt", "updatedAt"],
  "properties": {
    "bsId": { "$ref": "https://schemas.stravica.io/rcf/v0.3.0/common.schema.json#/$defs/bsId" },
    "prdId": { "$ref": "https://schemas.stravica.io/rcf/v0.3.0/common.schema.json#/$defs/prdId" },
    "version": { "$ref": "https://schemas.stravica.io/rcf/v0.3.0/common.schema.json#/$defs/version" },
    "status": { "$ref": "https://schemas.stravica.io/rcf/v0.3.0/common.schema.json#/$defs/authoringStatus" },
    "title": { "type": "string" },
    "buildPhilosophy": { "type": "string" },
    "generationStrategy": {
      "enum": ["verticalSlice", "dependencyFirst", "domainGrouped", "riskFrontLoaded"]
    },
    "createdAt": { "$ref": "https://schemas.stravica.io/rcf/v0.3.0/common.schema.json#/$defs/timestamp" },
    "updatedAt": { "$ref": "https://schemas.stravica.io/rcf/v0.3.0/common.schema.json#/$defs/timestamp" }
  }
}
