{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.stravica.io/rcf/v0.1.0/prd.schema.json",
  "title": "RCF PRD",
  "description": "Product Requirements Document. One per project. Shell document carrying requirementIds[]; REQ bodies live in req.schema.json files.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prdId",
    "productName",
    "version",
    "status",
    "problemStatement",
    "objectives",
    "requirementIds",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "prdId": { "$ref": "https://schemas.stravica.io/rcf/v0.1.0/common.schema.json#/$defs/prdId" },
    "productName": { "type": "string", "minLength": 1 },
    "version": { "$ref": "https://schemas.stravica.io/rcf/v0.1.0/common.schema.json#/$defs/version" },
    "status": { "$ref": "https://schemas.stravica.io/rcf/v0.1.0/common.schema.json#/$defs/authoringStatus" },
    "executiveSummary": { "type": "string" },
    "problemStatement": { "type": "string", "minLength": 1 },
    "targetUsers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "inScope": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "outOfScope": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "requirementIds": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://schemas.stravica.io/rcf/v0.1.0/common.schema.json#/$defs/reqId" }
    },
    "createdAt": { "$ref": "https://schemas.stravica.io/rcf/v0.1.0/common.schema.json#/$defs/timestamp" },
    "updatedAt": { "$ref": "https://schemas.stravica.io/rcf/v0.1.0/common.schema.json#/$defs/timestamp" }
  }
}
